# Docker / Community Edition settings for the mqo-eval buildloop.
# Source this file (or set these vars) before running the eval against the
# local AtScale Community Edition Docker stack instead of the live mcp-aws cluster.
#
# Fill in the TODO values for your deployment before use.

# ── MQO-MCP-SERVER endpoint (AtScale engine, Community Edition) ─────────────
# mqo-mcp-server connects here to resolve models and execute DAX/XMLA.
export MQO_ENDPOINT="localhost:15432"
export MQO_XMLA_URL="http://localhost/v1/xmla"
export MQO_OIDC_TOKEN_URL="http://localhost/auth/realms/atscale/protocol/openid-connect/token"
export MQO_OIDC_CLIENT_ID="atscale-mcp"
export MQO_OIDC_REALM="atscale"
# From community-edition docker-compose KC_ATSCALE_CLIENT_SECRET:
export ATSCALE_OIDC_SECRET="4YDv3q1iuflYuh2gf9BmwR0OJEIOSUibU2kYUtwoc3SaFAuNOn"

# ── Oracle: direct PGWire user/password (Community Edition) ─────────────────
# The oracle (--oracle pgwire) connects here to execute reference SQL.
# PGWire on Community Edition uses no TLS on localhost (sslmode=disable).
export ATSCALE_PG_USER="Admin"
# TODO: set ATSCALE_PG_PASS to your Community Edition Admin user's password.
# This is the password you set (or Keycloak generated) for the Admin account.
export ATSCALE_PG_PASS="TODO_community_edition_admin_password"

# ── Catalog / model coordinate ──────────────────────────────────────────────
# The SQL template uses ${CatalogName}.${ModelName}.
# TODO: set DOCKER_CATALOG_NAME to the schema/connection you created in
# Community Edition when deploying TPC-DS (e.g. '"atscale_catalogs"."tpcds_local"').
# DOCKER_MODEL_NAME is almost always tpcds_benchmark_model.
export DOCKER_CATALOG_NAME='"atscale_catalogs"."tpcds_Snowflake"'
export DOCKER_MODEL_NAME='"tpcds_benchmark_model"'
